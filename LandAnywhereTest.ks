// Land Anywhere Test script.

runpath
  (
    "LandAnywhere V01",
    "DEORBITATPE",                    // Deorbit type (DEORBITASAP,DEORBITATPE).
    20,                               // Landing height (m).
    3,                                // Landing speed (m/s).
    20,                               // Steering duration (secs).
    "NOWARP"                         // Warp type (NOWARP,RAILS,PHYSICS).
  ).